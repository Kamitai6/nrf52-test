{
    /* 
     * Requires the Rust Language Server (rust-analyzer) and Cortex-Debug extensions
     * https://marketplace.visualstudio.com/items?itemName=rust-lang.rust-analyzer
     * https://marketplace.visualstudio.com/items?itemName=marus25.cortex-debug
     */
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Cortex Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceRoot}",
            "preLaunchTask": "Cargo Build (debug)",
            "runToEntryPoint": "main",
            "executable": "${workspaceRoot}/target/thumbv8m.main-none-eabihf/debug/stm32h562",
            "device": "STM32H562RIT6",
            "searchDir": [
                "C:/OpenOCD/ocd/tcl",
            ],
            "configFiles": [
                "${workspaceRoot}/openocd.cfg",
            ],
            "svdFile": "${workspaceRoot}/STM32H562.svd",
        },
        {
            "name": "Cortex Debug (J-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "jlink",
            "interface": "swd", // 使用するインターフェース (JTAGの場合は "jtag")
            "device": "STM32H562RI", // マイクロコントローラーの型番に合わせて変更
            "executable": "${workspaceRoot}/target/thumbv8m.main-none-eabihf/debug/stm32h562",
            "svdFile": "${workspaceRoot}/STM32H562.svd",
            "cwd": "${workspaceRoot}",
            "preLaunchTask": "Cargo Build (debug)",
            "runToEntryPoint": "main",
            "serverArgs": [
                "-speed",
                "4000",
                "-endian",
                "little",
            ],
            "serverpath": "C:/Program Files/SEGGER/JLink_V810b/JLinkGDBServerCL.exe", // JLinkGDBServerのパス
            "showDevDebugOutput": "both",
            "rttConfig": {
                "enabled": true,
                "decoders": [
                    {
                        "port": 0,
                        "type": "console",
                        // "encoding": "unsigned",
                    }
                ],
            },
        },
    ]
}